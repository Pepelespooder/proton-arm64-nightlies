@@ -84,6 +85,53 @@
 static CRITICAL_SECTION dinput_hook_crit = { &dinput_critsect_debug, -1, 0, 0, 0, 0 };
 
 static struct list acquired_device_list = LIST_INIT( acquired_device_list );
+
+void dinput_keyboard_android_compat_mirror_state( IDirectInputDevice8W *iface, int dik_code, BYTE new_diks )
+{
+#ifdef __ANDROID__
+    struct dinput_device *device, *targets[8];
+    UINT count = 0, i;
+    DWORD id = DIDFT_PSHBUTTON | DIDFT_MAKEINSTANCE( dik_code );
+
+    if (!getenv( "WINE_ANDROID_DINPUT_COMPAT" )) return;
+
+    EnterCriticalSection( &dinput_hook_crit );
+    LIST_FOR_EACH_ENTRY( device, &acquired_device_list, struct dinput_device, entry )
+    {
+        if (&device->IDirectInputDevice8W_iface == iface) continue;
+        if (!IsEqualGUID( &device->guid, &GUID_SysKeyboard )) continue;
+        if (device->status != STATUS_ACQUIRED) continue;
+        if (device->use_raw_input) continue;
+        if (device->user_format.dwDataSize != 272) continue;
+        dinput_device_internal_addref( device );
+        targets[count++] = device;
+        if (count >= ARRAY_SIZE( targets )) break;
+    }
+    LeaveCriticalSection( &dinput_hook_crit );
+
+    for (i = 0; i < count; ++i)
+    {
+        struct dinput_device *target = targets[i];
+        DIOBJECTDATAFORMAT *obj;
+        int index;
+
+        EnterCriticalSection( &target->crit );
+        index = dinput_device_object_index_from_id( &target->IDirectInputDevice8W_iface, id );
+        if (index >= 0 && (obj = target->device_format.rgodf + index))
+        {
+            if (target->device_state[obj->dwOfs] != new_diks)
+            {
+                target->device_state[obj->dwOfs] = new_diks;
+                queue_event( &target->IDirectInputDevice8W_iface, index, new_diks, GetCurrentTime(), target->dinput->evsequence++ );
+                if (target->hEvent) SetEvent( target->hEvent );
+            }
+        }
+        LeaveCriticalSection( &target->crit );
+
+        dinput_device_internal_release( target );
+    }
+#endif
+}
 
